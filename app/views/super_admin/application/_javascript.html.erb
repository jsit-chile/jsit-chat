<%#
# Javascript Partial

This partial imports the necessary javascript on each page.
By default, it includes the application JS,
but each page can define additional JS sources
by providing a `content_for(:javascript)` block.
%>

<% Administrate::Engine.javascripts.each do |js_path| %>
  <%= javascript_include_tag js_path %>
<% end %>

<%= yield :javascript %>

<% if Rails.env.test? %>
  <%= javascript_tag do %>
    $.fx.off = true;
    $.ajaxSetup({ async: false });
  <% end %>
<% end %>

<script>
// Patch selectize BelongsToSearch: preload options on focus without requiring input.
// The gem's default load skips empty queries; we override it to call the backend
// with an empty search so the dropdown shows results immediately on click.
$(function() {
  function patchBelongsToSearch() {
    $('.field-unit--belongs-to-search select').each(function() {
      var sel = this.selectize;
      if (!sel || sel._jsitPatched) return;
      sel._jsitPatched = true;

      var url = sel.settings.searchUrl; // e.g. "/super_admin/accounts.json?search="

      // Replace load to allow empty queries
      sel.settings.load = function(query, callback) {
        $.ajax({
          url: url + encodeURIComponent(query),
          type: 'GET',
          error: function() { callback(); },
          success: function(res) { callback(res.resources || []); }
        });
      };

      // Preload on focus so options appear without typing
      sel.settings.preload = 'focus';

      // Trigger an immediate load to populate the list right now
      sel.load(function(callback) {
        $.ajax({
          url: url,
          type: 'GET',
          error: function() { callback(); },
          success: function(res) { callback(res.resources || []); }
        });
      });
    });
  }

  // Run after belongs_to_search.js initializes selectize (also on Turbo/ajax nav)
  setTimeout(patchBelongsToSearch, 150);
  $(document).on('page:load turbolinks:load', function() { setTimeout(patchBelongsToSearch, 150); });
});
</script>

<% if ChatwootHub.support_config[:support_website_token].present? && ChatwootHub.support_config[:support_script_url].present? %>
<script>
window.chatwootSettings = {
  hideMessageBubble: true,
};

(function(d,t) {
  var BASE_URL = '<%= ChatwootHub.support_config[:support_script_url] %>';
  var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
  g.src= BASE_URL + "/packs/js/sdk.js";
  g.async = true;
  s.parentNode.insertBefore(g,s);
  g.onload=function(){
    window.chatwootSDK.run({
      websiteToken: '<%= ChatwootHub.support_config[:support_website_token] %>',
      baseUrl: BASE_URL
    })
  }
})(document,"script");

window.addEventListener('chatwoot:ready', function() {
  window.$chatwoot.setUser('<%= ChatwootHub.installation_identifier %>', {
    identifier_hash: '<%= ChatwootHub.support_config[:support_identifier_hash] %>',
    email: '<%= SuperAdmin.first.email %>',
    name: '<%= SuperAdmin.first.name %>'
  });
})
</script>
<% end %>
